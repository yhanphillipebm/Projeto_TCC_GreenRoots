<Window x:Class="GreenRootsApp.PassaporteCompletoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Passaporte Digital Completo" 
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="White">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryGreenBrush" Color="#FF3b9351"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#FF4b2223"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#FFF5F5F5"/>
        
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>
        
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,10,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGreenBrush}" CornerRadius="5" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🌱" FontSize="28" Foreground="White"/>
                <TextBlock Text="PASSAPORTE DIGITAL GREEN ROOTS" 
                         Foreground="White" FontSize="18" FontWeight="Bold"
                         Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Conteúdo do Passaporte -->
        <ScrollViewer Grid.Row="1" Margin="0,15,0,0">
            <StackPanel>
                <!-- Informações Básicas -->
                <TextBlock Text="INFORMAÇÕES BÁSICAS" Style="{StaticResource HeaderText}"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Processo:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Nome}" Style="{StaticResource ValueText}" FontWeight="Bold"/>
                    
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Código:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Codigo}" Style="{StaticResource ValueText}" Foreground="{StaticResource PrimaryGreenBrush}" FontWeight="Bold"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Data/Hora:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TimestampProducao, StringFormat='dd/MM/yyyy HH:mm:ss'}" Style="{StaticResource ValueText}"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Status:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Status}" Style="{StaticResource ValueText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                </Grid>

                <!-- Materiais -->
                <TextBlock Text="MATERIAIS UTILIZADOS" Style="{StaticResource HeaderText}" Margin="0,20,0,0"/>
                <ItemsControl ItemsSource="{Binding Materiais}" Margin="20,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,2" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding}"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Métricas de Sustentabilidade -->
                <TextBlock Text="MÉTRICAS DE SUSTENTABILIDADE" Style="{StaticResource HeaderText}" Margin="0,20,0,0"/>
                
                <Grid Margin="20,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tempo de Produção:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TempoProducaoEstimado, StringFormat='{} {0} minutos'}" Style="{StaticResource ValueText}"/>
                    
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Emissão de CO₂:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding EmissaoCO2Estimada, StringFormat='{} {0} kg'}" Style="{StaticResource ValueText}" Foreground="DarkRed"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Energia Consumida:" Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EnergiaEstimada, StringFormat='{} {0} kWh'}" Style="{StaticResource ValueText}" Foreground="DarkOrange"/>
                </Grid>

                <!-- Sensores Ativados -->
                <TextBlock Text="SENSORES ATIVADOS" Style="{StaticResource HeaderText}" Margin="0,20,0,0"/>
                <ItemsControl ItemsSource="{Binding SensoresRequeridos}" Margin="20,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding}"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Eventos dos Sensores -->
                <TextBlock Text="EVENTOS REGISTRADOS" Style="{StaticResource HeaderText}" Margin="0,20,0,0"/>
                <ListView ItemsSource="{Binding EventosAssociados}" Height="150" Margin="10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="5" Background="{Binding StatusColor, Converter={StaticResource StatusToBrushConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TipoSensor}" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Evento}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Valor, StringFormat='{} {0} {1}'}" 
                                               HorizontalAlignment="Right" FontWeight="Bold"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Código de Verificação -->
                <TextBlock Text="CÓDIGO DE VERIFICAÇÃO" Style="{StaticResource HeaderText}" Margin="0,20,0,0"/>
                <Border Background="{StaticResource LightGrayBrush}" CornerRadius="5" Padding="15" Margin="10">
                    <TextBlock Text="{Binding CodigoVerificacaoCompleto}" 
                             FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                             HorizontalAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Rodapé com Botões -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="🖨️ Imprimir" Width="100" Height="35" Margin="0,0,10,0" Click="BtnImprimir_Click"/>
            <Button Content="💾 Salvar" Width="100" Height="35" Margin="0,0,10,0" Click="BtnSalvar_Click"/>
            <Button Content="✉️ Enviar" Width="100" Height="35" Margin="0,0,10,0" Click="BtnEnviar_Click"/>
            <Button Content="⬅️ Voltar" Width="100" Height="35" Click="BtnVoltar_Click"/>
        </StackPanel>
    </Grid>
</Window>