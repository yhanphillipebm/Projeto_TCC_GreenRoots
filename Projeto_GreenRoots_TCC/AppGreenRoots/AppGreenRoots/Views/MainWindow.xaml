<Window x:Class="AppGreenRoots.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppGreenRoots" Width="900" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="White">

    <Window.Resources>
        <!-- Cores da Logo -->
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#FF4b2223"/>
        <SolidColorBrush x:Key="PrimaryGreenBrush" Color="#FF3b9351"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#FF377a1b"/>
        <SolidColorBrush x:Key="LightGreenBrush" Color="#FF45aa45"/>
        <SolidColorBrush x:Key="HighlightGreenBrush" Color="#FF77b826"/>
        
        <!-- Estilos -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF4b2223"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F8F0"/>
                    <Setter Property="Foreground" Value="#FF3b9351"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3b9351"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF377a1b"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF4b2223"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3a1a1b"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Data Template para os dados dos sensores -->
        <DataTemplate x:Key="SensorDataTemplate">
            <Border Margin="0,0,0,5" Padding="10" Background="White"
                    CornerRadius="5" BorderBrush="#FFEEEEEE" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" 
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TipoSensor}" 
                               FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Evento}" 
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding Valor}" 
                               HorizontalAlignment="Right" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryGreenBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="{Binding Unidade}" 
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="{Binding CodigoVerificacao}" 
                               FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"
                               ToolTip="Código de Verificação" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="{Binding Status}" 
                               Foreground="{Binding StatusColor}" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Data Template para os passaportes de produção -->
        <DataTemplate x:Key="PassaporteDataTemplate">
            <Border Margin="0,0,0,10" Padding="15" Background="White"
                    CornerRadius="5" BorderBrush="#FFEEEEEE" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Nome}" 
                               FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource PrimaryDarkBrush}"/>
                    
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Status}" 
                               FontWeight="Bold" Margin="10,0,0,0"
                               Foreground="{Binding StatusColor}"/>
                    
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Código: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource PrimaryGreenBrush}"/>
                        <TextBlock Text=" • " Foreground="Gray"/>
                        <TextBlock Text="Tempo: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TempoProducaoEstimado}" Foreground="DarkBlue"/>
                        <TextBlock Text=" min" Foreground="Gray"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="CO₂: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding EmissaoCO2Estimada}" Foreground="DarkRed"/>
                        <TextBlock Text=" kg • " Foreground="Gray"/>
                        <TextBlock Text="Energia: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding EnergiaEstimada}" Foreground="DarkOrange"/>
                        <TextBlock Text=" kWh" Foreground="Gray"/>
                    </StackPanel>
                    
                    <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" 
                            Content="📋 Gerar" 
                            Click="BtnGerarPassaporte_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0"
                            Padding="10,5"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Style para a ListView -->
        <Style x:Key="ListViewStyle" TargetType="ListView">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Style para os itens da ListView -->
        <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE8F5E8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryGreenBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF0F8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGreenBrush}" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🌱" FontSize="28" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="SISTEMA DE PASSAPORTE DIGITAL - GREEN ROOTS" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Controles de Conexão -->
        <Border Grid.Row="1" Background="#FFF8F9FA" Padding="15" Margin="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Porta COM:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryDarkBrush}"/>
                <ComboBox x:Name="CmbPortasSerial" 
                          Width="120" 
                          Margin="0,0,10,0"
                          Height="30"/>
                <Button x:Name="BtnConectar" 
                        Content="🔌 Conectar" 
                        Click="BtnConectar_Click" 
                        Style="{StaticResource PrimaryButton}"
                        Width="100" 
                        Margin="0,0,10,0"
                        Height="30"/>
                <Button x:Name="BtnDesconectar" 
                        Content="🔋 Desconectar" 
                        Click="BtnDesconectar_Click" 
                        Style="{StaticResource SecondaryButton}"
                        Width="100" 
                        Margin="0,0,10,0" 
                        IsEnabled="False"
                        Height="30"/>
                <TextBlock x:Name="TxtStatus" 
                           Text="Status: Desconectado" 
                           Foreground="Red" 
                           VerticalAlignment="Center" 
                           FontWeight="SemiBold"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Área de Conteúdo com Abas -->
        <TabControl x:Name="TabControl" Grid.Row="2" Margin="10">
            <TabItem Header="📊 Monitoramento em Tempo Real">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Estatísticas -->
                    <TextBlock x:Name="TxtEstatisticas" 
                               Grid.Row="0" 
                               Margin="0,0,0,10"
                               TextWrapping="Wrap" 
                               FontSize="12" 
                               Foreground="Gray"
                               Text="Aguardando conexão com sensores..."/>

                    <!-- Lista de Dados de Sensores -->
                    <ListView x:Name="LvDadosSensores" 
                              Grid.Row="1"
                              ItemTemplate="{StaticResource SensorDataTemplate}"
                              Style="{StaticResource ListViewStyle}"
                              ItemContainerStyle="{StaticResource ListViewItemStyle}">
                    </ListView>
                </Grid>
            </TabItem>
            
            <TabItem Header="📋 Passaportes de Produção">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Margin="0,0,0,10"
                               TextWrapping="Wrap" 
                               FontSize="12" 
                               Foreground="Gray"
                               Text="Passaportes gerados automaticamente a partir dos dados dos sensores."/>
                    
                    <!-- Lista de Passaportes -->
                    <ListView x:Name="LvPassaportes" 
                              Grid.Row="1"
                              ItemTemplate="{StaticResource PassaporteDataTemplate}"
                              Style="{StaticResource ListViewStyle}"
                              ItemContainerStyle="{StaticResource ListViewItemStyle}">
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Rodapé com Botões de Ação -->
        <Border Grid.Row="3" Background="#FFF5F5F5" Padding="10" Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Exportar CSV" 
                        Click="BtnExportar_Click"
                        Style="{StaticResource PrimaryButton}" 
                        Margin="0,0,10,0"
                        Width="120"
                        Height="35"/>
                <Button Content="📋 Detalhes" 
                        Click="BtnDetalhes_Click"
                        Style="{StaticResource PrimaryButton}" 
                        Margin="0,0,10,0"
                        Width="100"
                        Height="35"/>
                <Button Content="✅ Validar" 
                        Click="BtnValidar_Click"
                        Style="{StaticResource PrimaryButton}" 
                        Margin="0,0,10,0"
                        Width="100"
                        Height="35"/>
                <Button Content="🗑️ Limpar" 
                        Click="BtnLimpar_Click"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Height="35"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
